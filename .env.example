# ─── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql://moduwa:moduwa@localhost:5432/moduwa

# ─── 공공데이터포털 / TourAPI ─────────────────────────────────
# 한국관광공사 관광지별 연관관광지 정보 (TarRlteTarService1)
# ⚠️ "디코딩" 키. (이 서비스키는 hex라 인코딩/디코딩 동일)
DATA_GO_KR_SERVICE_KEY=여기에_서비스키
MOBILE_APP=moduwa
MOBILE_OS=ETC

# 엔드포인트 (기본값이 areaBasedList1이라 보통 그대로 둠)
# TARRLTE_BASE_URL=http://apis.data.go.kr/B551011/TarRlteTarService1/areaBasedList1

# ─── 수집 범위 (기준연월) ─────────────────────────────────────
# 실제 데이터 가용범위: 202405 ~ 202605
BASE_YM_START=202405
BASE_YM_END=202605

# ─── 수집 튜닝 ───────────────────────────────────────────────
INGEST_NUM_OF_ROWS=5000        # 시군구당 보통 1요청으로 끝나도록 크게
INGEST_REQUEST_DELAY_MS=150    # 호출 간 딜레이(ms)
INGEST_MAX_RETRIES=5           # 페이지 실패 시 재시도

# 일일 요청 상한 (개발계정 1,000/일). 여유 두고 자동 중단 → 다음날 재개.
# 0 = 무제한(API 한도초과 에러에 의존)
INGEST_DAILY_REQUEST_CAP=900

# KorService2 상세 enrich 대상 유형. 기본=가볼곳만(개요·운영시간 가치高), 상업유형 제외.
# 12관광지 14문화시설 28레포츠 15축제 25여행코스 / (상업)32숙박 38쇼핑 39음식점
# 전체 원하면: 12,14,28,15,25,32,38,39
KORDETAIL_CONTENT_TYPES=12,14,28,15,25

# ─── 카카오 로컬 API (전화·카테고리·지도링크 보완) ───────────
# 발급: developers.kakao.com → 내 애플리케이션 → 앱 생성 → 앱 키 → REST API 키
KAKAO_REST_API_KEY=여기에_카카오_REST_API_키
KAKAO_DAILY_CAP=90000          # 카카오 무료 10만/일
KAKAO_CONCURRENCY=8            # 동시 요청 수

# ─── REST API 서버 (배포용) ──────────────────────────────────
PORT=8080
# 허용할 API 키 목록(콤마 구분). ⚠️ 배포 시 반드시 설정 — 비면 인증 없이 열림(로컬 개발 전용).
#   키 생성: node scripts/gen-api-key.mjs
API_KEYS=키1,키2
# CORS 허용 오리진(콤마 구분). 브라우저에서 직접 호출할 때만 의미. 서버간 호출이면 * 무방.
ALLOWED_ORIGINS=*
# API 키당 분당 요청 상한
RATE_LIMIT_PER_MIN=120

# ─── 관리형 DB 동기화 (선택) ─────────────────────────────────
# 설정하면 daily-ingest.sh 가 매일 수집 후 "API용 슬림 테이블"만 관리형 DB로 push한다.
# (무거운 수집 원본은 로컬에만 유지 → 관리형 디스크 절약). 값은 관리형 DB의 공개 URL.
# ⚠️ 관리형 DB 비밀번호를 로테이트하면 이 값도 갱신해야 한다.
# MANAGED_DATABASE_URL=postgresql://postgres:...@xxx.proxy.rlwy.net:포트/railway
